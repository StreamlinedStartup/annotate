{
  "branch_prefix": "sprout/",
  "base_branch": "main",
  "auto_checkout": true,
  "commit_on_done": true,
  "create_pr_on_epic_done": true,
  "prime_pull_requests": true,
  "pull_request_template_path": ".sprout/templates/PULL_REQUEST_TEMPLATE.md",
  "review_mode": "off",
  "drift_ignore": [
    "coverage/**",
    "*.log",
    "tmp/**",
    ".DS_Store"
  ],
  "auto_include_patterns": [
    "go.sum",
    "go.mod"
  ]
}
